{
  "name": "orontes-medikal-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.13.1",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "qa:visual": "node scripts/run-visual-qa.mjs",
    "env:check": "node scripts/env-check.mjs",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "db:studio": "node node_modules/prisma/build/index.js studio",
    "db:seed": "node node_modules/prisma/build/index.js db seed",
    "db:validate": "node node_modules/prisma/build/index.js validate",
    "admin:bootstrap": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/admin-bootstrap.ts",
    "admin:list-users": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/admin-list-users.ts",
    "admin:rotate-password": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/admin-rotate-password.ts",
    "service-requests:import": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/service-requests-import.ts",
    "mail:process": "tsx scripts/mail-process.ts",
    "mail:verify": "node scripts/mail-verify.mjs",
    "mail:test": "node scripts/mail-test.mjs",
    "blog:publish-due": "node scripts/blog-publish-due.mjs",
    "backup:database": "node scripts/db-backup.mjs",
    "backup:verify": "node scripts/db-restore-check.mjs",
    "storage:migrate:dry-run": "node scripts/storage-migrate-dry-run.mjs",
    "security:audit": "npm audit --audit-level=moderate",
    "dependencies:check": "npm outdated || true",
    "production:check": "node scripts/production-check.mjs",
    "test:e2e:service-requests": "playwright test --config=playwright.e2e.config.ts tests/e2e/service-requests.spec.ts",
    "test:e2e:rbac": "playwright test --config=playwright.e2e.config.ts tests/e2e/rbac.spec.ts",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-type": "^22.0.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "postcss": "^8.5.16"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "argon2@0.44.0": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "sharp@0.35.3": true,
    "unrs-resolver@1.12.2": true
  }
}
