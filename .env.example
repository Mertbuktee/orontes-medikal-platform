APP_ORIGIN=http://localhost:3000
TRUST_PROXY=false
ADMIN_DEV_BYPASS=false

# Local development only. Use a strong, environment-managed secret in production.
POSTGRES_USER=orontes_dev
POSTGRES_PASSWORD=LOCAL_ONLY_PASSWORD
POSTGRES_DB=orontes_medikal
POSTGRES_PORT=5432

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/orontes_medikal?schema=public"

# Admin authentication bootstrap. Do not commit real values.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_SESSION_MAX_AGE_SECONDS=36000
ADMIN_REMEMBER_SESSION_MAX_AGE_SECONDS=2592000
PASSWORD_RESET_TOKEN_TTL_SECONDS=2700

# Transactional email. Development writes reset links to storage/private/auth/.
MAIL_PROVIDER=development
MAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Base64 encoded 32-byte key. Required before enabling MFA in production.
MFA_ENCRYPTION_KEY=

# Explicit password rotation. Do not commit real values.
ADMIN_ROTATE_EMAIL=
ADMIN_ROTATE_PASSWORD=
ADMIN_ROTATE_CONFIRM=ROTATE_ADMIN_PASSWORD
