generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  SERVICE_STAFF
  VIEWER
}

enum ServiceRequestStatus {
  NEW
  REVIEWING
  WAITING_FOR_CUSTOMER
  APPROVED
  IN_REPAIR
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  LOGIN
  LOGIN_FAILURE
  LOGOUT
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  STATUS_CHANGE
  SESSION_REVOKED
  PASSWORD_CHANGED
  ACCOUNT_LOCKED
}

enum MediaCategory {
  GENERAL
  HERO
  DEVICE
  SERVICE
  BLOG
  SEO
  BRAND
  LEGAL
}

enum MediaUsageType {
  IMAGE
  DOCUMENT
  LOGO
  FAVICON
  OPEN_GRAPH
}

enum MediaVariantType {
  ORIGINAL
  THUMBNAIL
  MEDIUM
  LARGE
}

model User {
  id                    String                        @id @default(cuid())
  name                  String                        @db.VarChar(120)
  email                 String                        @unique @db.VarChar(254)
  passwordHash          String
  role                  Role                          @default(VIEWER)
  isActive              Boolean                       @default(true)
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  failedLoginCount      Int                           @default(0)
  lockedUntil           DateTime?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  adminSessions         AdminSession[]                @relation("AdminUserSessions")
  assignedRequests      ServiceRequest[]              @relation("AssignedServiceRequests")
  authoredNotes         ServiceRequestNote[]          @relation("ServiceRequestNoteAuthor")
  statusChanges         ServiceRequestStatusHistory[] @relation("ServiceRequestStatusChanger")
  uploadedMedia         Media[]                       @relation("MediaUploader")
  heroSlidesUpdated     HeroSlide[]                   @relation("HeroSlideUpdater")
  authoredPosts         BlogPost[]                    @relation("BlogPostAuthor")
  updatedSettings       SiteSetting[]                 @relation("SiteSettingUpdater")
  auditLogs             AuditLog[]                    @relation("AuditLogActor")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([lockedUntil])
}

model AdminSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation("AdminUserSessions", fields: [userId], references: [id], onDelete: Restrict)
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  ipAddress  String?   @db.VarChar(64)
  userAgent  String?   @db.VarChar(512)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt, expiresAt])
}

model ServiceRequest {
  id                 String                        @id @default(cuid())
  fullName           String                        @db.VarChar(100)
  company            String                        @db.VarChar(150)
  phone              String                        @db.VarChar(30)
  email              String                        @db.VarChar(254)
  deviceBrand        String?                       @db.VarChar(120)
  deviceModel        String?                       @db.VarChar(120)
  deviceSerialNumber String?                       @db.VarChar(120)
  message            String
  status             ServiceRequestStatus          @default(NEW)
  assignedUserId     String?
  assignedUser       User?                         @relation("AssignedServiceRequests", fields: [assignedUserId], references: [id], onDelete: SetNull)
  attachments        Attachment[]
  internalNotes      ServiceRequestNote[]
  statusHistory      ServiceRequestStatusHistory[]
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  archivedAt         DateTime?

  @@index([status])
  @@index([assignedUserId])
  @@index([createdAt])
  @@index([archivedAt])
}

model Attachment {
  id               String         @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  storageKey       String         @unique
  mimeType         String         @db.VarChar(120)
  size             Int
  originalName     String?        @db.VarChar(255)
  createdAt        DateTime       @default(now())

  @@index([serviceRequestId])
  @@index([createdAt])
}

model ServiceRequestNote {
  id               String         @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  authorId         String
  author           User           @relation("ServiceRequestNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  content          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([serviceRequestId])
  @@index([authorId])
  @@index([createdAt])
}

model ServiceRequestStatusHistory {
  id               String               @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  fromStatus       ServiceRequestStatus?
  toStatus         ServiceRequestStatus
  changedById      String
  changedBy        User                 @relation("ServiceRequestStatusChanger", fields: [changedById], references: [id], onDelete: Restrict)
  createdAt        DateTime             @default(now())

  @@index([serviceRequestId])
  @@index([changedById])
  @@index([createdAt])
}

model DeviceGroup {
  id               String   @id
  title            String   @db.VarChar(160)
  slug             String   @unique @db.VarChar(180)
  shortDescription String
  fullDescription  String
  iconKey          String   @db.VarChar(80)
  capabilities     String[]
  isFeatured       Boolean  @default(false)
  order            Int
  isActive         Boolean  @default(true)
  seoTitle         String   @db.VarChar(180)
  seoDescription   String   @db.VarChar(320)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([order])
  @@index([isActive, isFeatured, order])
}

model Service {
  id               String   @id
  title            String   @db.VarChar(160)
  slug             String   @unique @db.VarChar(180)
  shortDescription String
  fullDescription  String
  iconKey          String   @db.VarChar(80)
  isFeatured       Boolean  @default(false)
  order            Int
  isActive         Boolean  @default(true)
  seoTitle         String   @db.VarChar(180)
  seoDescription   String   @db.VarChar(320)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([order])
  @@index([isActive, isFeatured, order])
}

model Media {
  id             String      @id @default(cuid())
  storageKey     String      @unique
  originalName   String?     @db.VarChar(255)
  mimeType       String      @db.VarChar(120)
  size           Int
  width          Int?
  height         Int?
  altText        String?
  title          String      @default("Untitled media") @db.VarChar(150)
  description    String?
  category       MediaCategory @default(GENERAL)
  usageType      MediaUsageType @default(IMAGE)
  contentHash    String?     @unique @db.VarChar(64)
  archivedAt     DateTime?
  uploadedById   String?
  uploadedBy     User?       @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  variants       MediaVariant[]
  heroSlides     HeroSlide[] @relation("HeroSlideImage")
  blogPostCovers BlogPost[]  @relation("BlogPostCoverImage")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([uploadedById])
  @@index([category])
  @@index([usageType])
  @@index([mimeType])
  @@index([createdAt])
  @@index([archivedAt])
}

model MediaVariant {
  id         String           @id @default(cuid())
  mediaId    String
  media      Media            @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  variant    MediaVariantType
  storageKey String           @unique
  mimeType   String           @db.VarChar(120)
  width      Int?
  height     Int?
  size       Int
  createdAt  DateTime         @default(now())

  @@unique([mediaId, variant])
  @@index([mediaId])
  @@index([variant])
}

model HeroSlide {
  id                String   @id
  title             String   @db.VarChar(180)
  description       String
  badge             String?  @db.VarChar(80)
  imageId           String
  image             Media    @relation("HeroSlideImage", fields: [imageId], references: [id], onDelete: Restrict)
  imageAlt          String
  linkUrl           String?  @db.VarChar(500)
  order             Int
  isActive          Boolean  @default(true)
  includeInAutoplay Boolean  @default(true)
  updatedById       String?
  updatedBy         User?    @relation("HeroSlideUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([order])
  @@index([isActive, includeInAutoplay, order])
  @@index([imageId])
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(120)
  slug      String     @unique @db.VarChar(160)
  posts     BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String        @db.VarChar(180)
  slug           String        @unique @db.VarChar(220)
  excerpt        String
  content        Json
  status         ContentStatus @default(DRAFT)
  categoryId     String
  category       BlogCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  coverImageId   String?
  coverImage     Media?        @relation("BlogPostCoverImage", fields: [coverImageId], references: [id], onDelete: Restrict)
  authorId       String
  author         User          @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  seoTitle       String        @db.VarChar(180)
  seoDescription String        @db.VarChar(320)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([coverImageId])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(120)
  value       Json
  type        String   @db.VarChar(60)
  updatedById String?
  updatedBy   User?    @relation("SiteSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([updatedById])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actor      User?       @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String      @db.VarChar(120)
  entityId   String?
  metadata   Json?
  ipAddress  String?     @db.VarChar(64)
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}
