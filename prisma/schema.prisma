generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  SERVICE_STAFF
  VIEWER
}

enum ServiceRequestStatus {
  NEW
  REVIEWING
  WAITING_FOR_CUSTOMER
  APPROVED
  IN_REPAIR
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  LOGIN
  LOGIN_FAILURE
  LOGOUT
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  STATUS_CHANGE
  SESSION_REVOKED
  ALL_SESSIONS_REVOKED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  MFA_ENROLLMENT_STARTED
  MFA_ENABLED
  MFA_DISABLED
  MFA_RECOVERY_CODES_REGENERATED
  MFA_CHALLENGE_SUCCESS
  MFA_CHALLENGE_FAILURE
  RECOVERY_CODE_USED
  ACCOUNT_LOCKED
}

enum NotificationCategory {
  SERVICE_REQUEST_NEW
  SERVICE_REQUEST_ASSIGNED
  SERVICE_REQUEST_STATUS_CHANGED
  SERVICE_REQUEST_NOTE_ADDED
  CONTENT_PUBLISHED
  CONTENT_SCHEDULED
  SECURITY_ALERT
  PASSWORD_CHANGED
  MFA_CHANGED
  SESSION_REVOKED
  SYSTEM_ALERT
}

enum EmailDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
  RETRY_SCHEDULED
  CANCELLED
}

enum CustomerDeviceStatus {
  ACTIVE
  UNDER_SERVICE
  OUT_OF_SERVICE
  RETIRED
  ARCHIVED
}

enum CustomerDeviceCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MediaCategory {
  GENERAL
  HERO
  DEVICE
  SERVICE
  BLOG
  SEO
  BRAND
  LEGAL
}

enum MediaUsageType {
  IMAGE
  DOCUMENT
  LOGO
  FAVICON
  OPEN_GRAPH
}

enum MediaVariantType {
  ORIGINAL
  THUMBNAIL
  MEDIUM
  LARGE
}

model User {
  id                    String                        @id @default(cuid())
  name                  String                        @db.VarChar(120)
  email                 String                        @unique @db.VarChar(254)
  passwordHash          String
  role                  Role                          @default(VIEWER)
  isActive              Boolean                       @default(true)
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  failedLoginCount      Int                           @default(0)
  lockedUntil           DateTime?
  mfaEnabled            Boolean                       @default(false)
  mfaVerifiedAt         DateTime?
  securityVersion       Int                           @default(1)
  createdById           String?
  createdBy             User?                         @relation("UserCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers          User[]                        @relation("UserCreator")
  updatedById           String?
  updatedBy             User?                         @relation("UserUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedUsers          User[]                        @relation("UserUpdater")
  deactivatedAt         DateTime?
  deactivatedById       String?
  deactivatedBy         User?                         @relation("UserDeactivator", fields: [deactivatedById], references: [id], onDelete: SetNull)
  deactivatedUsers      User[]                        @relation("UserDeactivator")
  deactivationReason    String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  adminSessions         AdminSession[]                @relation("AdminUserSessions")
  passwordResetTokens   PasswordResetToken[]          @relation("UserPasswordResetTokens")
  mfaCredentials        MfaCredential[]               @relation("UserMfaCredentials")
  mfaRecoveryCodes      MfaRecoveryCode[]             @relation("UserMfaRecoveryCodes")
  assignedRequests      ServiceRequest[]              @relation("AssignedServiceRequests")
  authoredNotes         ServiceRequestNote[]          @relation("ServiceRequestNoteAuthor")
  statusChanges         ServiceRequestStatusHistory[] @relation("ServiceRequestStatusChanger")
  completedDeviceHistories DeviceServiceHistory[]      @relation("DeviceServiceHistoryCompletedBy")
  uploadedMedia         Media[]                       @relation("MediaUploader")
  heroSlidesCreated     HeroSlide[]                   @relation("HeroSlideCreator")
  heroSlidesUpdated     HeroSlide[]                   @relation("HeroSlideUpdater")
  deviceGroupsCreated   DeviceGroup[]                 @relation("DeviceGroupCreator")
  deviceGroupsUpdated   DeviceGroup[]                 @relation("DeviceGroupUpdater")
  servicesCreated       Service[]                     @relation("ServiceCreator")
  servicesUpdated       Service[]                     @relation("ServiceUpdater")
  homepageSectionsUpdated HomepageSection[]           @relation("HomepageSectionUpdater")
  authoredPosts         BlogPost[]                    @relation("BlogPostAuthor")
  blogPostsCreated      BlogPost[]                    @relation("BlogPostCreator")
  blogPostsUpdated      BlogPost[]                    @relation("BlogPostUpdater")
  blogPostRevisions     BlogPostRevision[]            @relation("BlogPostRevisionCreator")
  updatedSettings       SiteSetting[]                 @relation("SiteSettingUpdater")
  auditLogs             AuditLog[]                    @relation("AuditLogActor")
  notificationPreferences NotificationPreference[]     @relation("UserNotificationPreferences")
  notifications         Notification[]                 @relation("UserNotifications")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([createdById])
  @@index([updatedById])
  @@index([deactivatedById])
  @@index([deactivatedAt])
  @@index([lockedUntil])
  @@index([mfaEnabled])
}

model AdminSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation("AdminUserSessions", fields: [userId], references: [id], onDelete: Restrict)
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  ipAddress  String?   @db.VarChar(64)
  userAgent  String?   @db.VarChar(512)
  remembered Boolean   @default(false)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt, expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserPasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  requestedIp String?   @db.VarChar(64)
  userAgent   String?   @db.VarChar(512)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([userId, usedAt, expiresAt])
}

model MfaCredential {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("UserMfaCredentials", fields: [userId], references: [id], onDelete: Cascade)
  encryptedSecret String
  verifiedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([verifiedAt])
  @@index([revokedAt])
  @@index([userId, revokedAt])
}

model MfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserMfaRecoveryCodes", fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([usedAt])
  @@index([userId, usedAt])
}

model ServiceRequest {
  id                 String                        @id @default(cuid())
  fullName           String                        @db.VarChar(100)
  company            String                        @db.VarChar(150)
  phone              String                        @db.VarChar(30)
  email              String                        @db.VarChar(254)
  deviceBrand        String?                       @db.VarChar(120)
  deviceModel        String?                       @db.VarChar(120)
  deviceSerialNumber String?                       @db.VarChar(120)
  message            String
  status             ServiceRequestStatus          @default(NEW)
  assignedUserId     String?
  assignedUser       User?                         @relation("AssignedServiceRequests", fields: [assignedUserId], references: [id], onDelete: SetNull)
  customerCompanyId  String?
  customerCompany    CustomerCompany?              @relation(fields: [customerCompanyId], references: [id], onDelete: SetNull)
  customerLocationId String?
  customerLocation   CustomerLocation?             @relation(fields: [customerLocationId], references: [id], onDelete: SetNull)
  customerContactId  String?
  customerContact    CustomerContact?              @relation(fields: [customerContactId], references: [id], onDelete: SetNull)
  customerDeviceId   String?
  customerDevice     CustomerDevice?               @relation(fields: [customerDeviceId], references: [id], onDelete: SetNull)
  attachments        Attachment[]
  internalNotes      ServiceRequestNote[]
  statusHistory      ServiceRequestStatusHistory[]
  deviceHistory      DeviceServiceHistory?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  archivedAt         DateTime?

  @@index([status])
  @@index([assignedUserId])
  @@index([customerCompanyId])
  @@index([customerLocationId])
  @@index([customerContactId])
  @@index([customerDeviceId])
  @@index([createdAt])
  @@index([archivedAt])
}

model CustomerCompany {
  id              String             @id @default(cuid())
  legalName       String             @db.VarChar(180)
  displayName     String             @db.VarChar(180)
  phone           String             @db.VarChar(30)
  email           String             @db.VarChar(254)
  taxNumber       String?            @db.VarChar(50)
  taxOffice       String?            @db.VarChar(120)
  notes           String?
  isActive        Boolean            @default(true)
  archivedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  locations       CustomerLocation[]
  contacts        CustomerContact[]
  devices         CustomerDevice[]
  serviceRequests ServiceRequest[]

  @@index([legalName])
  @@index([displayName])
  @@index([phone])
  @@index([email])
  @@index([taxNumber])
  @@index([isActive])
  @@index([archivedAt])
  @@index([createdAt])
}

model CustomerLocation {
  id                String           @id @default(cuid())
  customerCompanyId String
  customerCompany   CustomerCompany  @relation(fields: [customerCompanyId], references: [id], onDelete: Cascade)
  name              String           @db.VarChar(160)
  city              String           @db.VarChar(80)
  district          String           @db.VarChar(80)
  addressLine       String
  department        String?          @db.VarChar(120)
  building          String?          @db.VarChar(120)
  floor             String?          @db.VarChar(40)
  phone             String?          @db.VarChar(30)
  isPrimary         Boolean          @default(false)
  isActive          Boolean          @default(true)
  archivedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  contacts          CustomerContact[]
  devices           CustomerDevice[]
  serviceRequests   ServiceRequest[]

  @@index([customerCompanyId])
  @@index([city])
  @@index([district])
  @@index([isPrimary])
  @@index([isActive])
  @@index([archivedAt])
}

model CustomerContact {
  id                 String            @id @default(cuid())
  customerCompanyId  String
  customerCompany    CustomerCompany   @relation(fields: [customerCompanyId], references: [id], onDelete: Cascade)
  customerLocationId String?
  customerLocation   CustomerLocation? @relation(fields: [customerLocationId], references: [id], onDelete: SetNull)
  fullName           String            @db.VarChar(120)
  title              String?           @db.VarChar(120)
  department         String?           @db.VarChar(120)
  phone              String            @db.VarChar(30)
  email              String?           @db.VarChar(254)
  isPrimary          Boolean           @default(false)
  isActive           Boolean           @default(true)
  archivedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  serviceRequests    ServiceRequest[]

  @@index([customerCompanyId])
  @@index([customerLocationId])
  @@index([fullName])
  @@index([phone])
  @@index([email])
  @@index([isPrimary])
  @@index([isActive])
  @@index([archivedAt])
}

model Manufacturer {
  id              String           @id @default(cuid())
  name            String           @db.VarChar(160)
  slug            String           @unique @db.VarChar(180)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deviceModels    DeviceModel[]
  customerDevices CustomerDevice[]

  @@index([name])
  @@index([isActive])
}

model DeviceModel {
  id              String           @id @default(cuid())
  manufacturerId  String
  manufacturer    Manufacturer     @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  name            String           @db.VarChar(160)
  deviceGroupId   String?
  deviceGroup     DeviceGroup?     @relation("DeviceModelDeviceGroup", fields: [deviceGroupId], references: [id], onDelete: SetNull)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customerDevices CustomerDevice[]

  @@index([manufacturerId])
  @@index([deviceGroupId])
  @@index([name])
  @@index([isActive])
  @@unique([manufacturerId, name])
}

model CustomerDevice {
  id                      String                    @id @default(cuid())
  publicCode              String                    @unique @db.VarChar(32)
  customerCompanyId       String
  customerCompany         CustomerCompany           @relation(fields: [customerCompanyId], references: [id], onDelete: Cascade)
  customerLocationId      String
  customerLocation        CustomerLocation          @relation(fields: [customerLocationId], references: [id], onDelete: Restrict)
  deviceGroupId           String?
  deviceGroup             DeviceGroup?              @relation("CustomerDeviceDeviceGroup", fields: [deviceGroupId], references: [id], onDelete: SetNull)
  manufacturerId          String?
  manufacturer            Manufacturer?             @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  deviceModelId           String?
  deviceModel             DeviceModel?              @relation(fields: [deviceModelId], references: [id], onDelete: SetNull)
  customManufacturer      String?                   @db.VarChar(160)
  customModel             String?                   @db.VarChar(160)
  serialNumber            String                    @db.VarChar(160)
  assetTag                String?                   @db.VarChar(120)
  hospitalInventoryNumber String?                   @db.VarChar(120)
  department              String?                   @db.VarChar(120)
  room                    String?                   @db.VarChar(120)
  installationDate        DateTime?
  purchaseDate            DateTime?
  warrantyEndDate         DateTime?
  status                  CustomerDeviceStatus      @default(ACTIVE)
  criticality             CustomerDeviceCriticality @default(MEDIUM)
  notes                   String?
  lastServiceAt           DateTime?
  isActive                Boolean                   @default(true)
  archivedAt              DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  serviceRequests         ServiceRequest[]

  @@index([publicCode])
  @@index([customerCompanyId])
  @@index([customerLocationId])
  @@index([deviceGroupId])
  @@index([manufacturerId])
  @@index([deviceModelId])
  @@index([serialNumber])
  @@index([assetTag])
  @@index([hospitalInventoryNumber])
  @@index([status])
  @@index([criticality])
  @@index([lastServiceAt])
  @@index([isActive])
  @@index([archivedAt])
  @@index([manufacturerId, serialNumber])
}

model Attachment {
  id               String         @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  storageKey       String         @unique
  mimeType         String         @db.VarChar(120)
  size             Int
  originalName     String?        @db.VarChar(255)
  createdAt        DateTime       @default(now())

  @@index([serviceRequestId])
  @@index([createdAt])
}

model ServiceRequestNote {
  id               String         @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  authorId         String
  author           User           @relation("ServiceRequestNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  content          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([serviceRequestId])
  @@index([authorId])
  @@index([createdAt])
}

model ServiceRequestStatusHistory {
  id               String               @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  fromStatus       ServiceRequestStatus?
  toStatus         ServiceRequestStatus
  changedById      String
  changedBy        User                 @relation("ServiceRequestStatusChanger", fields: [changedById], references: [id], onDelete: Restrict)
  createdAt        DateTime             @default(now())

  @@index([serviceRequestId])
  @@index([changedById])
  @@index([createdAt])
}

model DeviceServiceHistory {
  id                 String         @id @default(cuid())
  serviceRequestId   String         @unique
  serviceRequest     ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  completedById      String?
  completedBy        User?          @relation("DeviceServiceHistoryCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  fullName           String         @db.VarChar(100)
  company            String         @db.VarChar(150)
  phone              String         @db.VarChar(30)
  email              String         @db.VarChar(254)
  deviceBrand        String?        @db.VarChar(120)
  deviceModel        String?        @db.VarChar(120)
  deviceSerialNumber String?        @db.VarChar(120)
  serviceSummary     String
  completedAt        DateTime       @default(now())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([completedAt])
  @@index([completedById])
  @@index([email])
  @@index([phone])
  @@index([deviceSerialNumber])
  @@index([deviceBrand, deviceModel])
}

model DeviceGroup {
  id               String    @id
  title            String    @db.VarChar(160)
  slug             String    @unique @db.VarChar(180)
  shortDescription String
  fullDescription  String
  iconKey          String    @db.VarChar(80)
  imageId          String?
  image            Media?    @relation("DeviceGroupImage", fields: [imageId], references: [id], onDelete: SetNull)
  capabilities     String[]
  isFeatured       Boolean   @default(false)
  order            Int
  isActive         Boolean   @default(true)
  seoTitle         String    @db.VarChar(180)
  seoDescription   String    @db.VarChar(320)
  openGraphImageId String?
  openGraphImage   Media?    @relation("DeviceGroupOpenGraphImage", fields: [openGraphImageId], references: [id], onDelete: SetNull)
  createdById      String?
  createdBy        User?     @relation("DeviceGroupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?
  updatedBy        User?     @relation("DeviceGroupUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deviceModels     DeviceModel[]    @relation("DeviceModelDeviceGroup")
  customerDevices  CustomerDevice[] @relation("CustomerDeviceDeviceGroup")

  @@index([title])
  @@index([imageId])
  @@index([openGraphImageId])
  @@index([createdById])
  @@index([updatedById])
  @@index([order])
  @@index([isActive, isFeatured, order])
  @@index([archivedAt])
}

model Service {
  id               String    @id
  title            String    @db.VarChar(160)
  slug             String    @unique @db.VarChar(180)
  shortDescription String
  fullDescription  String
  iconKey          String    @db.VarChar(80)
  imageId          String?
  image            Media?    @relation("ServiceImage", fields: [imageId], references: [id], onDelete: SetNull)
  isFeatured       Boolean   @default(false)
  order            Int
  isActive         Boolean   @default(true)
  seoTitle         String    @db.VarChar(180)
  seoDescription   String    @db.VarChar(320)
  openGraphImageId String?
  openGraphImage   Media?    @relation("ServiceOpenGraphImage", fields: [openGraphImageId], references: [id], onDelete: SetNull)
  ctaLabel         String?   @db.VarChar(120)
  ctaHref          String?   @db.VarChar(300)
  createdById      String?
  createdBy        User?     @relation("ServiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?
  updatedBy        User?     @relation("ServiceUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?

  @@index([imageId])
  @@index([openGraphImageId])
  @@index([createdById])
  @@index([updatedById])
  @@index([order])
  @@index([isActive, isFeatured, order])
  @@index([archivedAt])
}

model Media {
  id             String      @id @default(cuid())
  storageKey     String      @unique
  originalName   String?     @db.VarChar(255)
  mimeType       String      @db.VarChar(120)
  size           Int
  width          Int?
  height         Int?
  altText        String?
  title          String      @default("Untitled media") @db.VarChar(150)
  description    String?
  category       MediaCategory @default(GENERAL)
  usageType      MediaUsageType @default(IMAGE)
  contentHash    String?     @unique @db.VarChar(64)
  archivedAt     DateTime?
  uploadedById   String?
  uploadedBy     User?       @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  variants       MediaVariant[]
  heroSlides     HeroSlide[] @relation("HeroSlideImage")
  deviceGroups   DeviceGroup[] @relation("DeviceGroupImage")
  deviceGroupOpenGraphs DeviceGroup[] @relation("DeviceGroupOpenGraphImage")
  services       Service[] @relation("ServiceImage")
  serviceOpenGraphs Service[] @relation("ServiceOpenGraphImage")
  blogPostCovers BlogPost[]  @relation("BlogPostCoverImage")
  blogPostOpenGraphs BlogPost[] @relation("BlogPostOpenGraphImage")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([uploadedById])
  @@index([category])
  @@index([usageType])
  @@index([mimeType])
  @@index([createdAt])
  @@index([archivedAt])
}

model MediaVariant {
  id         String           @id @default(cuid())
  mediaId    String
  media      Media            @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  variant    MediaVariantType
  storageKey String           @unique
  mimeType   String           @db.VarChar(120)
  width      Int?
  height     Int?
  size       Int
  createdAt  DateTime         @default(now())

  @@unique([mediaId, variant])
  @@index([mediaId])
  @@index([variant])
}

model HeroSlide {
  id                String   @id
  title             String   @db.VarChar(180)
  description       String
  badge             String?  @db.VarChar(80)
  imageId           String
  image             Media    @relation("HeroSlideImage", fields: [imageId], references: [id], onDelete: Restrict)
  imageAlt          String
  linkUrl           String?  @db.VarChar(500)
  linkLabel         String?  @db.VarChar(120)
  objectPosition    String   @default("center") @db.VarChar(40)
  order             Int
  isActive          Boolean  @default(true)
  includeInAutoplay Boolean  @default(true)
  createdById       String?
  createdBy         User?    @relation("HeroSlideCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById       String?
  updatedBy         User?    @relation("HeroSlideUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([order])
  @@index([isActive, includeInAutoplay, order])
  @@index([imageId])
  @@index([createdById])
  @@index([updatedById])
}

model BlogCategory {
  id             String     @id @default(cuid())
  name           String     @db.VarChar(120)
  slug           String     @unique @db.VarChar(160)
  description    String?
  seoTitle       String     @default("") @db.VarChar(180)
  seoDescription String     @default("") @db.VarChar(320)
  order          Int        @default(1)
  isActive       Boolean    @default(true)
  posts          BlogPost[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  archivedAt     DateTime?

  @@index([order])
  @@index([isActive, order])
  @@index([archivedAt])
}

model BlogPost {
  id               String        @id @default(cuid())
  title            String        @db.VarChar(200)
  slug             String        @unique @db.VarChar(180)
  excerpt          String
  content          Json
  status           ContentStatus @default(DRAFT)
  categoryId       String?
  category         BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  coverImageId     String?
  coverImage       Media?        @relation("BlogPostCoverImage", fields: [coverImageId], references: [id], onDelete: Restrict)
  openGraphImageId String?
  openGraphImage   Media?        @relation("BlogPostOpenGraphImage", fields: [openGraphImageId], references: [id], onDelete: Restrict)
  authorId         String?
  author           User?         @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  seoTitle         String        @db.VarChar(180)
  seoDescription   String        @db.VarChar(320)
  isFeatured       Boolean       @default(false)
  viewCount        Int           @default(0)
  publishedAt      DateTime?
  scheduledFor     DateTime?
  createdById      String?
  createdBy        User?         @relation("BlogPostCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?
  updatedBy        User?         @relation("BlogPostUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  revisions        BlogPostRevision[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  archivedAt       DateTime?

  @@index([status, publishedAt])
  @@index([status, scheduledFor])
  @@index([categoryId])
  @@index([authorId])
  @@index([coverImageId])
  @@index([openGraphImageId])
  @@index([createdById])
  @@index([updatedById])
  @@index([isFeatured, status, publishedAt])
  @@index([viewCount])
  @@index([archivedAt])
}

model BlogPostRevision {
  id             String   @id @default(cuid())
  blogPostId     String
  blogPost       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  title          String   @db.VarChar(200)
  excerpt        String
  content        Json
  seoTitle       String   @db.VarChar(180)
  seoDescription String   @db.VarChar(320)
  createdById    String?
  createdBy      User?    @relation("BlogPostRevisionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([blogPostId])
  @@index([createdById])
  @@index([createdAt])
}

model HomepageSection {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(80)
  title       String   @db.VarChar(180)
  eyebrow     String?  @db.VarChar(80)
  description String
  content     Json
  order       Int
  isVisible   Boolean  @default(true)
  updatedById String?
  updatedBy   User?    @relation("HomepageSectionUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([isVisible, order])
  @@index([updatedById])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(120)
  value       Json
  type        String   @db.VarChar(60)
  updatedById String?
  updatedBy   User?    @relation("SiteSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([updatedById])
}

model NotificationPreference {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)
  category     NotificationCategory
  emailEnabled Boolean              @default(true)
  inAppEnabled Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([userId, category])
  @@index([userId])
  @@index([category])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  title     String               @db.VarChar(180)
  message   String               @db.VarChar(1000)
  linkUrl   String?              @db.VarChar(300)
  readAt    DateTime?
  createdAt DateTime             @default(now())
  expiresAt DateTime?
  deliveries EmailDelivery[]     @relation("NotificationEmailDeliveries")

  @@index([userId, readAt, createdAt])
  @@index([category])
  @@index([expiresAt])
}

model EmailDelivery {
  id                String              @id @default(cuid())
  notificationId    String?
  notification      Notification?       @relation("NotificationEmailDeliveries", fields: [notificationId], references: [id], onDelete: SetNull)
  templateKey       String              @db.VarChar(120)
  templatePayload   Json
  recipient         String              @db.VarChar(254)
  subject           String              @db.VarChar(220)
  provider          String              @db.VarChar(60)
  providerMessageId String?             @db.VarChar(180)
  status            EmailDeliveryStatus @default(PENDING)
  attemptCount      Int                 @default(0)
  lastAttemptAt     DateTime?
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  errorCode         String?             @db.VarChar(120)
  errorSummary      String?             @db.VarChar(500)
  idempotencyKey    String?             @unique @db.VarChar(220)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attempts          EmailDeliveryAttempt[]

  @@index([status, nextAttemptAt])
  @@index([recipient])
  @@index([templateKey])
  @@index([createdAt])
  @@index([notificationId])
}

model EmailDeliveryAttempt {
  id              String              @id @default(cuid())
  emailDeliveryId String
  emailDelivery   EmailDelivery       @relation(fields: [emailDeliveryId], references: [id], onDelete: Cascade)
  attemptNumber   Int
  status          EmailDeliveryStatus
  errorCode       String?             @db.VarChar(120)
  errorSummary    String?             @db.VarChar(500)
  attemptedAt     DateTime            @default(now())

  @@index([emailDeliveryId])
  @@index([attemptedAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actor      User?       @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String      @db.VarChar(120)
  entityId   String?
  metadata   Json?
  ipAddress  String?     @db.VarChar(64)
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([actorId])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([entityType, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
  @@index([action])
  @@index([action, createdAt])
}
